#!/bin/bash

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
. "${SCRIPT_DIR}/common"

export_runtime_env() {
    export HOME="${VAR_DIR}/home"
    export NODE_ENV=production
    export PORT="$PORT_VALUE"
    export BIND_HOST=0.0.0.0
    export HERMES_HOME="${VAR_DIR}/hermes"
    export HERMES_WEB_UI_HOME="${VAR_DIR}/hermes-web-ui"
    export HERMES_WEBUI_STATE_DIR="${VAR_DIR}/hermes-web-ui"
    export UPLOAD_DIR="${VAR_DIR}/hermes-web-ui/upload"
    export HERMES_BIN="$HERMES_BIN_VALUE"
    export HERMES_AGENT_CLI_PYTHON="$PYTHON_BIN"
    export HERMES_AGENT_BRIDGE_PYTHON="$PYTHON_BIN"
    export HERMES_AGENT_BRIDGE_ENDPOINT="ipc://${RUN_DIR}/agent-bridge.sock"
    export HERMES_WEB_UI_MANAGED_GATEWAY=1
    export HERMES_ALLOW_ROOT_GATEWAY=1
    export PATH="${APP_DIR}/runtime/node/bin:${PYTHON_HOME}/bin:${PATH}"
}

start_app() {
    if app_is_running; then
        echo "Hermes Studio is already running"
        exit 0
    fi

    stop_all_processes
    prepare_dirs
    persist_runtime_config || exit 1

    if ! ensure_executable "$NODE_BIN"; then
        write_error "Node runtime missing or not executable: $NODE_BIN"
        exit 1
    fi

    PYTHON_BIN="$(resolve_python)"
    if [ -z "$PYTHON_BIN" ]; then
        write_error "Python runtime missing or not executable: ${PYTHON_HOME}/bin/python3, ${PYTHON_HOME}/bin/python, or ${PYTHON_HOME}/bin/python3.12"
        exit 1
    fi

    HERMES_BIN_VALUE="${PYTHON_HOME}/bin/hermes"
    if ! ensure_executable "$HERMES_BIN_VALUE"; then
        write_error "Hermes binary missing or not executable: $HERMES_BIN_VALUE"
        exit 1
    fi
    if [ ! -f "$SERVER_ENTRY" ]; then
        write_error "Hermes Studio server entry missing: $SERVER_ENTRY"
        exit 1
    fi

    export_runtime_env

    cd "$SERVER_DIR" || exit 1
    if command -v setsid >/dev/null 2>&1; then
        nohup setsid "$NODE_BIN" "$SERVER_ENTRY" >> "$LOG_FILE" 2>&1 &
    else
        nohup "$NODE_BIN" "$SERVER_ENTRY" >> "$LOG_FILE" 2>&1 &
    fi
    echo $! > "$PID_FILE"
    sleep 2

    if app_is_running; then
        echo "Hermes Studio started on port ${PORT_VALUE}"
        exit 0
    fi

    rm -f "$PID_FILE"
    write_error "Hermes Studio failed to start. Check ${LOG_FILE}"
    exit 1
}

stop_app() {
    if app_is_running; then
        stop_all_processes
        echo "Hermes Studio stopped"
        exit 0
    fi

    stop_all_processes
    echo "Hermes Studio is not running"
    exit 0
}

case $1 in
start)
    start_app
    ;;
stop)
    stop_app
    ;;
status)
    if app_is_running; then
        echo "Hermes Studio is running"
        exit 0
    else
        echo "Hermes Studio is not running"
        exit 3
    fi
    ;;
log)
    tail -n "${2:-100}" "$LOG_FILE"
    ;;
*)
    exit 1
    ;;
esac
